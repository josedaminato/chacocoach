# Trainer Config (JSON stringificado, para deploy multi-trainer)
# Si no se define, usa lib/config.ts como fallback
TRAINER_CONFIG=

# Site (para SEO, sitemap, OG)
NEXT_PUBLIC_SITE_URL=https://tudominio.com

# Sanity (crear proyecto en sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# Resend (emails de contacto - resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@tudominio.com

# Studio (protección del panel de administración)
STUDIO_PASSWORD=
# URL del Studio desplegado (sanity deploy). Si no se define, se usa https://<projectId>.sanity.studio
NEXT_PUBLIC_SANITY_STUDIO_URL=

# Opcional: Google Analytics
NEXT_PUBLIC_GA_ID=
